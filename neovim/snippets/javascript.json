{
  "Console Log": {
    "prefix": "cl",
    "body": ["console.log('$1:', $2);", "$0"],
    "description": "Console log with label"
  },
  "Console Error": {
    "prefix": "ce",
    "body": ["console.error('$1:', $2);", "$0"],
    "description": "Console error with label"
  },
  "Arrow Function": {
    "prefix": "af",
    "body": ["const ${1:name} = ($2) => {", "  $0", "};"],
    "description": "Arrow function"
  },
  "Async Function": {
    "prefix": "asf",
    "body": ["async function ${1:name}($2) {", "  $0", "}"],
    "description": "Async function"
  },
  "IIFE": {
    "prefix": "iife",
    "body": ["(async () => {", "  $0", "})();"],
    "description": "Immediately invoked async function"
  },
  "Try Catch": {
    "prefix": "tc",
    "body": ["try {", "  $1", "} catch (${2:err}) {", "  console.error($2);", "  $0", "}"],
    "description": "Try catch block"
  },
  "Fetch API": {
    "prefix": "fetch",
    "body": ["const ${1:response} = await fetch(${2:url}, {", "  method: '${3:GET}',", "  headers: {", "    'Content-Type': 'application/json',", "  },", "});", "const ${4:data} = await $1.json();"],
    "description": "Fetch API call"
  },
  "JSON Parse/Stringify": {
    "prefix": "json",
    "body": ["JSON.parse(${1:string})", "$0"],
    "description": "Parse JSON"
  },
  "Require Module": {
    "prefix": "req",
    "body": ["const ${1:module} = require('$2');", "$0"],
    "description": "Require a module"
  },
  "Export Default": {
    "prefix": "exp",
    "body": ["export default $1;"],
    "description": "Export default"
  },
  "Import Default": {
    "prefix": "imp",
    "body": ["import ${1:name} from '$2';"],
    "description": "Import default"
  },
  "Import Named": {
    "prefix": "imn",
    "body": ["import { $1 } from '$2';"],
    "description": "Import named"
  },
  "Destructuring Object": {
    "prefix": "dest",
    "body": ["const { $1 } = ${2:object};"],
    "description": "Destructuring object"
  },
  "Destructuring Array": {
    "prefix": "desta",
    "body": ["const [$1] = ${2:array};"],
    "description": "Destructuring array"
  },
  "React useState": {
    "prefix": "usestate",
    "body": ["const [$1, set${2:State}] = useState($3);", "$0"],
    "description": "React useState hook"
  },
  "React useEffect": {
    "prefix": "useffect",
    "body": ["useEffect(() => {", "  $1", "}, [$0]);"],
    "description": "React useEffect hook"
  },
  "React useRef": {
    "prefix": "useref",
    "body": ["const $1 = useRef($2);", "$0"],
    "description": "React useRef hook"
  },
  "React Component": {
    "prefix": "rfc",
    "body": ["export function ${1:Component}({ $2 }) {", "  return (", "    <div>$0</div>", "  );", "}"],
    "description": "React functional component"
  },
  "React Component with TS": {
    "prefix": "rfc-ts",
    "body": ["interface ${1:Component}Props {", "  $2", "}", "", "export function ${1:Component}({ $2 }: ${1:Component}Props) {", "  return (", "    <div>$0</div>", "  );", "}"],
    "description": "React functional component with TypeScript"
  },
  "Vue Script Setup": {
    "prefix": "vue",
    "body": ["<script setup lang=\"ts\">", "$1", "</script>", "", "<template>", "  <div>$0</div>", "</template>"],
    "description": "Vue 3 script setup"
  },
  "Describe Block": {
    "prefix": "desc",
    "body": ["describe('$1', () => {", "  $0", "});"],
    "description": "Jest describe block"
  },
  "It Block": {
    "prefix": "it",
    "body": ["it('should $1', () => {", "  $0", "});"],
    "description": "Jest it block"
  },
  "Test Block": {
    "prefix": "test",
    "body": ["test('$1', () => {", "  $0", "});"],
    "description": "Jest test block"
  },
  "Before Each": {
    "prefix": "be",
    "body": ["beforeEach(() => {", "  $0", "});"],
    "description": "Jest beforeEach"
  }
}
