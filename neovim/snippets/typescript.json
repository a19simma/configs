{
  "Console Log": {
    "prefix": "cl",
    "body": ["console.log('$1:', $1);", "$0"],
    "description": "Console log"
  },
  "Arrow Function": {
    "prefix": "af",
    "body": ["const ${1:name} = ($2): ${3:void} => {", "  $0", "};"],
    "description": "Arrow function with type"
  },
  "Async Function": {
    "prefix": "asf",
    "body": ["async function ${1:name}($2): Promise<${3:void}> {", "  $0", "}"],
    "description": "Async function with return type"
  },
  "Type Interface": {
    "prefix": "ti",
    "body": ["interface ${1:Name} {", "  $2: ${3:string};", "  $0", "}"],
    "description": "TypeScript interface"
  },
  "Type Alias": {
    "prefix": "ta",
    "body": ["type ${1:Name} = {", "  $2: ${3:string};", "  $0", "};"],
    "description": "TypeScript type alias"
  },
  "Enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "  ${2:Option1} = '$2',", "  ${3:Option2} = '$3',", "}"],
    "description": "TypeScript enum"
  },
  "Class": {
    "prefix": "class",
    "body": ["class ${1:Name} {", "  constructor($2) {", "    $3", "  }", "", "  $0", "}"],
    "description": "TypeScript class"
  },
  "Class with Private": {
    "prefix": "classp",
    "body": ["class ${1:Name} {", "  private ${2:prop}: ${3:string};", "", "  constructor($2: $3) {", "    this.$2 = $2;", "  }", "", "  public get ${4:getter}(): $3 {", "    return this.$2;", "  }", "}"],
    "description": "TypeScript class with private prop"
  },
  "Generic Function": {
    "prefix": "genf",
    "body": ["function ${1:name}<${2:T}>($3: ${2:T}): ${2:T} {", "  return $3;", "}"],
    "description": "Generic function"
  },
  "Generic Arrow": {
    "prefix": "gena",
    "body": ["const ${1:name} = <${2:T},>($3: ${2:T}): ${2:T} => $3;"],
    "description": "Generic arrow function"
  },
  "Try Catch": {
    "prefix": "tc",
    "body": ["try {", "  $1", "} catch (${2:err}) {", "  if (err instanceof Error) console.error(err.message);", "  $0", "}"],
    "description": "Try catch with error typing"
  },
  "Export Interface": {
    "prefix": "exi",
    "body": ["export interface ${1:Name} {", "  $2", "}"],
    "description": "Export interface"
  },
  "Export Type": {
    "prefix": "ext",
    "body": ["export type ${1:Name} = $2;"],
    "description": "Export type"
  },
  "Import Type": {
    "prefix": "imt",
    "body": ["import type { $1 } from '$2';"],
    "description": "Import type only"
  },
  "Record Type": {
    "prefix": "rec",
    "body": ["Record<${1:string}, ${2:any}>"],
    "description": "Record type"
  },
  "Partial Type": {
    "prefix": "part",
    "body": ["Partial<${1:Type}>"],
    "description": "Partial type"
  },
  "Required Type": {
    "prefix": "reqt",
    "body": ["Required<${1:Type}>"],
    "description": "Required type"
  },
  "Pick Type": {
    "prefix": "pick",
    "body": ["Pick<${1:Type}, '$2'>"],
    "description": "Pick type"
  },
  "Omit Type": {
    "prefix": "omit",
    "body": ["Omit<${1:Type}, '$2'>"],
    "description": "Omit type"
  },
  "React FC with Props": {
    "prefix": "rfc",
    "body": ["interface ${1:Component}Props {", "  $2", "}", "", "export const ${1:Component}: React.FC<${1:Component}Props> = ({ $2 }) => {", "  return (", "    <div>$0</div>", "  );", "};"],
    "description": "React functional component with props"
  },
  "React FC": {
    "prefix": "rfcsimple",
    "body": ["export const ${1:Component}: React.FC = () => {", "  return (", "    <div>$0</div>", "  );", "};"],
    "description": "Simple React functional component"
  },
  "useState with Type": {
    "prefix": "usestate",
    "body": ["const [$1, set${2:State}] = useState<${3:string}>($4);", "$0"],
    "description": "React useState with type"
  },
  "useEffect": {
    "prefix": "useffect",
    "body": ["useEffect(() => {", "  $1", "}, [$0]);"],
    "description": "React useEffect"
  },
  "useRef": {
    "prefix": "useref",
    "body": ["const $1 = useRef<${2:HTMLDivElement}>($3);", "$0"],
    "description": "React useRef with type"
  },
  "useCallback": {
    "prefix": "usecb",
    "body": ["const ${1:callback} = useCallback(($2) => {", "  $0", "}, [$3]);"],
    "description": "React useCallback"
  },
  "useMemo": {
    "prefix": "usememo",
    "body": ["const ${1:value} = useMemo(() => {", "  return $2;", "}, [$3]);", "$0"],
    "description": "React useMemo"
  },
  "Vue Script Setup TS": {
    "prefix": "vue",
    "body": ["<script setup lang=\"ts\">", "$1", "</script>", "", "<template>", "  <div>$0</div>", "</template>"],
    "description": "Vue 3 script setup with TS"
  },
  "Describe Block": {
    "prefix": "desc",
    "body": ["describe('$1', () => {", "  $0", "});"],
    "description": "Jest describe block"
  },
  "It Block": {
    "prefix": "it",
    "body": ["it('should $1', async () => {", "  $0", "});"],
    "description": "Jest it block"
  },
  "Test Block": {
    "prefix": "test",
    "body": ["test('$1', async () => {", "  $0", "});"],
    "description": "Jest test block"
  },
  "Expect": {
    "prefix": "exp",
    "body": ["expect($1).toBe($2);", "$0"],
    "description": "Jest expect"
  },
  "Expect Async": {
    "prefix": "expa",
    "body": ["await expect($1).resolves.toBe($2);", "$0"],
    "description": "Jest expect async"
  }
}
