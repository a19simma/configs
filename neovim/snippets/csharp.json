{
  "Class": {
    "prefix": "class",
    "body": ["public class ${1:ClassName}", "{", "    $0", "}"],
    "description": "Class declaration"
  },
  "Public Class": {
    "prefix": "pubclass",
    "body": ["public class ${1:ClassName}", "{", "    public ${1:ClassName}()", "    {", "    }", "", "    $0", "}"],
    "description": "Public class with constructor"
  },
  "Interface": {
    "prefix": "interface",
    "body": ["public interface I${1:InterfaceName}", "{", "    $0", "}"],
    "description": "Interface declaration"
  },
  "Method": {
    "prefix": "method",
    "body": ["public ${1:void} ${2:MethodName}($3)", "{", "    $0", "}"],
    "description": "Method declaration"
  },
  "Void Method": {
    "prefix": "void",
    "body": ["public void ${1:MethodName}()", "{", "    $0", "}"],
    "description": "Void method"
  },
  "Async Task": {
    "prefix": "async",
    "body": ["public async Task<${1:T}> ${2:MethodName}()", "{", "    $0", "}"],
    "description": "Async method returning Task"
  },
  "Async Void": {
    "prefix": "asyncv",
    "body": ["public async Task ${1:MethodName}()", "{", "    $0", "}"],
    "description": "Async method returning void Task"
  },
  "Property": {
    "prefix": "prop",
    "body": ["public ${1:string} ${2:PropertyName} { get; set; }"],
    "description": "Auto-property"
  },
  "Property Full": {
    "prefix": "propg",
    "body": ["private ${1:string} _${2:property};", "", "public ${1:string} ${2:PropertyName}", "{", "    get => _${2:property};", "    set => _${2:property} = value;", "}"],
    "description": "Full property with backing field"
  },
  "Constructor": {
    "prefix": "ctor",
    "body": ["public ${1:ClassName}($2)", "{", "    $0", "}"],
    "description": "Constructor"
  },
  "For Loop": {
    "prefix": "for",
    "body": ["for (int ${1:i} = 0; ${1:i} < ${2:length}; ${1:i}++)", "{", "    $0", "}"],
    "description": "For loop"
  },
  "ForEach": {
    "prefix": "foreach",
    "body": ["foreach (var ${1:item} in ${2:collection})", "{", "    $0", "}"],
    "description": "ForEach loop"
  },
  "If Statement": {
    "prefix": "if",
    "body": ["if (${1:condition})", "{", "    $0", "}"],
    "description": "If statement"
  },
  "If Else": {
    "prefix": "ifelse",
    "body": ["if (${1:condition})", "{", "    $2", "}", "else", "{", "    $0", "}"],
    "description": "If else statement"
  },
  "Switch": {
    "prefix": "switch",
    "body": ["switch (${1:expression})", "{", "    case ${2:value}:", "        break;", "    default:", "        break;", "}"],
    "description": "Switch statement"
  },
  "Try Catch": {
    "prefix": "try",
    "body": ["try", "{", "    $1", "}", "catch (${2:Exception} ${3:ex})", "{", "    $0", "}"],
    "description": "Try catch block"
  },
  "Using": {
    "prefix": "using",
    "body": ["using (var ${1:resource} = new ${2:Resource}())", "{", "    $0", "}"],
    "description": "Using statement"
  },
  "Namespace": {
    "prefix": "namespace",
    "body": ["namespace ${1:Namespace}", "{", "    $0", "}"],
    "description": "Namespace declaration"
  },
  "Region": {
    "prefix": "region",
    "body": ["#region ${1:Name}", "$0", "#endregion"],
    "description": "Code region"
  },
  "Console WriteLine": {
    "prefix": "cw",
    "body": ["Console.WriteLine($1);", "$0"],
    "description": "Console.WriteLine"
  },
  "String Interpolation": {
    "prefix": "str",
    "body": ["$\"$1{$2}\"", "$0"],
    "description": "String interpolation"
  },
  "Null Check": {
    "prefix": "null",
    "body": ["if (${1:item} == null)", "{", "    $0", "}"],
    "description": "Null check"
  },
  "Linq Select": {
    "prefix": "select",
    "body": [".Select(x => new { $1 })", "$0"],
    "description": "Linq Select"
  },
  "Linq Where": {
    "prefix": "where",
    "body": [".Where(x => x.$1)", "$0"],
    "description": "Linq Where"
  },
  "Linq FirstOrDefault": {
    "prefix": "first",
    "body": [".FirstOrDefault()", "$0"],
    "description": "Linq FirstOrDefault"
  },
  "Record": {
    "prefix": "record",
    "body": ["public record ${1:RecordName}($2);", "$0"],
    "description": "Record declaration"
  },
  "Record Class": {
    "prefix": "recordc",
    "body": ["public record ${1:RecordName}", "{", "    public ${2:string} ${3:Property} { get; init; }", "}", "$0"],
    "description": "Record class"
  },
  "Test Class": {
    "prefix": "testc",
    "body": "[TestClass]", "public class ${1:ClassName}Tests", "{", "    $0", "}"],
    "description": "Test class"
  },
  "Test Method": {
    "prefix": "test",
    "body": ["[TestMethod]", "public void ${1:TestMethod}_Test()", "{", "    $0", "}"],
    "description": "Test method"
  },
  "xUnit Test": {
    "prefix": "fact",
    "[Fact]", "public void ${1:TestMethod}_Test()", "{", "    $0", "}"],
    "description": "xUnit test method"
  },
  "ASP.NET Controller": {
    "prefix": "controller",
    "body": "[ApiController]", "[Route(\"[controller]\")]", "public class ${1:Name}Controller : ControllerBase", "{", "    $0", "}"],
    "description": "API Controller"
  },
  "ASP.NET Action": {
    "prefix": "action",
    "body": ["[HttpGet]", "public async Task<IActionResult> ${1:ActionName}()", "{", "    $0", "}"],
    "description": "HTTP action"
  },
  "Dependency Injection": {
    "prefix": "inject",
    "body": ["private readonly I${1:Service} _${2:service};", "", "public ${3:ClassName}(I${1:Service} ${2:service})", "{", "    _${2:service} = ${2:service};", "}"],
    "description": "Constructor injection"
  },
  "Log": {
    "prefix": "log",
    "body": ["_logger.Log${1:Information}(\"$2\");", "$0"],
    "description": "Logger call"
  }
}
